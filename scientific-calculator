<script>
// ================================================================
// STATE
// ================================================================
const S = {
    current: '0',
    pendingVal: null,
    pendingOp: null,
    waitingOp: false,
    justCalc: false,
    memory: 0,
    hasMemory: false,
    angleMode: 'DEG',
    is2nd: false,
    history: JSON.parse(localStorage.getItem('calcHistory') || '[]'),
    mode: 'standard',
    theme: localStorage.getItem('calcTheme') || 'dark',
    calcCount: parseInt(localStorage.getItem('calcCount') || '0'),
    graphCount: parseInt(localStorage.getItem('graphCount') || '0'),
    sessionStart: Date.now(),
    graphFunctions: [],
    chartInstance: null,
    selectedPlan: 'yearly',
    converterType: 'length',
    deferredPrompt: null
};

// ================================================================
// DISPLAY
// ================================================================
function updateDisplay() {
    const main = document.getElementById('displayMain');
    const expr = document.getElementById('displayExpression');

    main.textContent = S.current;
    const len = S.current.length;
    main.classList.remove('small','xsmall');
    if (len > 15) main.classList.add('xsmall');
    else if (len > 10) main.classList.add('small');

    let exprTxt = '';
    if (S.pendingVal !== null && S.pendingOp) {
        exprTxt = `${fmtNum(S.pendingVal)} ${S.pendingOp}`;
    }
    expr.textContent = exprTxt;

    document.getElementById('memBadge').classList.toggle('active', S.hasMemory);
    document.getElementById('angleBadge').textContent = S.angleMode;
    const ab = document.getElementById('btnAngle');
    if (ab) ab.textContent = S.angleMode;
    updateStats();
}

function fmtNum(n) {
    if (!isFinite(n) || isNaN(n)) return String(n);
    const s = String(n);
    return s.length > 12 ? parseFloat(n.toPrecision(10)).toString() : s;
}

function fmtResult(n) {
    if (isNaN(n)) return 'NaN';
    if (!isFinite(n)) return n > 0 ? 'Infinity' : '-Infinity';
    let r = parseFloat(n.toPrecision(12));
    let s = String(r);
    if (s.length > 15) s = n.toExponential(6);
    return s;
}

function showError(msg) {
    S.current = msg || 'Error';
    S.waitingOp = true;
    S.justCalc = false;
    updateDisplay();
    const d = document.getElementById('display');
    d.classList.add('shake');
    setTimeout(() => d.classList.remove('shake'), 400);
}

// ================================================================
// INPUT
// ================================================================
function appendNum(d, e) {
    ripple(e);
    if (S.waitingOp) { S.current = d; S.waitingOp = false; }
    else if (S.justCalc) { S.current = d; S.justCalc = false; S.pendingVal = null; S.pendingOp = null; }
    else {
        if (S.current === '0' && d !== '.') S.current = d;
        else if (S.current.length < 16) S.current += d;
    }
    updateDisplay();
}

function appendDec(e) {
    ripple(e);
    if (S.waitingOp || S.justCalc) { S.current = '0.'; S.waitingOp = false; S.justCalc = false; }
    else if (!S.current.includes('.')) S.current += '.';
    updateDisplay();
}

function appendOp(op, e) {
    ripple(e);
    const cur = parseFloat(S.current);
    if (S.pendingOp && !S.waitingOp) {
        const res = computeBasic(S.pendingVal, cur, S.pendingOp);
        if (res === null) return;
        S.current = fmtResult(res);
        S.pendingVal = parseFloat(S.current);
    } else {
        S.pendingVal = cur;
    }
    S.pendingOp = op;
    S.waitingOp = true;
    S.justCalc = false;
    updateDisplay();
}

function computeBasic(a, b, op) {
    switch (op) {
        case '+': return a + b;
        case '−': return a - b;
        case '×': return a * b;
        case '÷': if (b === 0) { showError('Cannot ÷ 0'); return null; } return a / b;
        case 'xⁿ': return Math.pow(a, b);
        case 'ʸ√': return Math.pow(b, 1/a);
    }
    return b;
}

// ================================================================
// CALCULATE
// ================================================================
function calculate(e) {
    ripple(e);
    if (!S.pendingOp && S.pendingVal === null) return;
    if (S.waitingOp) return;

    const cur = parseFloat(S.current);
    if (isNaN(cur)) return;

    const res = computeBasic(S.pendingVal, cur, S.pendingOp);
    if (res === null) return;

    const exprStr = `${fmtNum(S.pendingVal)} ${S.pendingOp} ${fmtNum(cur)}`;
    const resStr = fmtResult(res);

    addHistory(exprStr, resStr);
    S.calcCount++;
    localStorage.setItem('calcCount', S.calcCount);

    S.current = resStr;
    S.pendingVal = null;
    S.pendingOp = null;
    S.waitingOp = false;
    S.justCalc = true;
    updateDisplay();
}

// ================================================================
// CLEAR / BACKSPACE
// ================================================================
function clearAll(e) {
    ripple(e);
    S.current = '0';
    S.pendingVal = null;
    S.pendingOp = null;
    S.waitingOp = false;
    S.justCalc = false;
    updateDisplay();
}

function backspace(e) {
    ripple(e);
    if (S.justCalc || S.waitingOp) { S.current = '0'; S.waitingOp = false; S.justCalc = false; }
    else S.current = S.current.slice(0,-1) || '0';
    updateDisplay();
}

function toggleSign(e) {
    ripple(e);
    const v = parseFloat(S.current);
    if (!isNaN(v)) { S.current = fmtResult(-v); updateDisplay(); }
}

function percentage(e) {
    ripple(e);
    const v = parseFloat(S.current);
    if (!isNaN(v)) { S.current = fmtResult(v/100); updateDisplay(); }
}

// ================================================================
// SCIENTIFIC
// ================================================================
function toRad(d) { return d * Math.PI / 180; }
function toDeg(r) { return r * 180 / Math.PI; }
function getAng(v) { return S.angleMode === 'DEG' ? toRad(v) : v; }

function toggle2nd(e) {
    ripple(e);
    S.is2nd = !S.is2nd;
    const b = document.getElementById('btn2nd');
    b.style.background = S.is2nd ? 'rgba(100,200,255,0.3)' : '';
    const labels = S.is2nd
        ? { sin:'sin⁻¹', cos:'cos⁻¹', tan:'tan⁻¹' }
        : { sin:'sin', cos:'cos', tan:'tan' };
    ['sin','cos','tan'].forEach(k => {
        const el = document.getElementById('btn'+k.charAt(0).toUpperCase()+k.slice(1));
        if (el) el.textContent = labels[k];
    });
}

function toggleAngle(e) {
    ripple(e);
    S.angleMode = S.angleMode === 'DEG' ? 'RAD' : 'DEG';
    updateDisplay();
}

function sciFn(fn, e) {
    ripple(e);
    const v = parseFloat(S.current);
    let res;

    if (fn === 'sin' || fn === 'cos' || fn === 'tan') {
        if (S.is2nd) fn = 'a' + fn;
    }

    try {
        switch (fn) {
            case 'sin': res = Math.sin(getAng(v)); break;
            case 'cos': res = Math.cos(getAng(v)); break;
            case 'tan':
                if (S.angleMode==='DEG' && v%180===90) { showError('Undefined'); return; }
                res = Math.tan(getAng(v)); break;
            case 'asin': if(Math.abs(v)>1){showError('Domain Error');return;} res=S.angleMode==='DEG'?toDeg(Math.asin(v)):Math.asin(v); break;
            case 'acos': if(Math.abs(v)>1){showError('Domain Error');return;} res=S.angleMode==='DEG'?toDeg(Math.acos(v)):Math.acos(v); break;
            case 'atan': res=S.angleMode==='DEG'?toDeg(Math.atan(v)):Math.atan(v); break;
            case 'x²': res=v*v; break;
            case 'x³': res=v*v*v; break;
            case 'xⁿ': S.pendingVal=v; S.pendingOp='xⁿ'; S.waitingOp=true; updateDisplay(); return;
            case 'eˣ': res=Math.exp(v); break;
            case '10ˣ': res=Math.pow(10,v); break;
            case '√': if(v<0){showError('Domain Error');return;} res=Math.sqrt(v); break;
            case '∛': res=Math.cbrt(v); break;
            case 'ʸ√': S.pendingVal=v; S.pendingOp='ʸ√'; S.waitingOp=true; updateDisplay(); return;
            case 'ln': if(v<=0){showError('Domain Error');return;} res=Math.log(v); break;
            case 'log': if(v<=0){showError('Domain Error');return;} res=Math.log10(v); break;
            case '1/x': if(v===0){showError('Cannot ÷ 0');return;} res=1/v; break;
            case '|x|': res=Math.abs(v); break;
            case 'n!': if(v<0||v!==Math.floor(v)){showError('Domain Error');return;} res=factorial(v); break;
            case 'π': S.current=String(Math.PI); S.justCalc=true; updateDisplay(); return;
            case 'e': S.current=String(Math.E); S.justCalc=true; updateDisplay(); return;
            case 'Rand': res=Math.random(); break;
            case 'EE': S.current+='e'; updateDisplay(); return;
            case '(': case ')': return;
            default: return;
        }
        if (res === undefined) return;
        const rs = fmtResult(res);
        addHistory(`${fn}(${v})`, rs);
        S.calcCount++;
        localStorage.setItem('calcCount', S.calcCount);
        S.current = rs;
        S.justCalc = true;
        S.waitingOp = false;
        updateDisplay();
    } catch(err) { showError('Error'); }
}

function factorial(n) {
    if (n>170) return Infinity;
    if (n<=1) return 1;
    let r=1; for(let i=2;i<=n;i++) r*=i; return r;
}

// ================================================================
// MEMORY
// ================================================================
function memAct(act, e) {
    ripple(e);
    const v = parseFloat(S.current);
    switch(act) {
        case 'MC': S.memory=0; S.hasMemory=false; break;
        case 'MR': S.current=fmtResult(S.memory); S.justCalc=true; break;
        case 'MS': S.memory=v; S.hasMemory=true; break;
        case 'M+': S.memory+=v; S.hasMemory=true; break;
        case 'M-': S.memory-=v; S.hasMemory=true; break;
    }
    updateDisplay();
    showNotif(`Memory: ${fmtResult(S.memory)}`);
}

// ================================================================
// HISTORY
// ================================================================
function addHistory(expr, result) {
    S.history.unshift({ expr, result, time: new Date().toLocaleTimeString() });
    if (S.history.length > 100) S.history.pop();
    localStorage.setItem('calcHistory', JSON.stringify(S.history));
    renderHistory();
}

function renderHistory() {
    const html = S.history.length === 0
        ? '<div style="text-align:center;color:var(--text-secondary);padding:20px;font-size:13px">No history yet</div>'
        : S.history.map((h,i) => `
            <div class="history-item" onclick="useHistory(${i})">
                <div>
                    <div class="h-expr">${h.expr}</div>
                    <div class="h-result">= ${h.result}</div>
                </div>
                <div class="history-time">${h.time}</div>
            </div>`).join('');

    const el1 = document.getElementById('calcHistoryList');
    const el2 = document.getElementById('sideHistoryList');
    if (el1) el1.innerHTML = html;
    if (el2) el2.innerHTML = html;
}

function useHistory(i) {
    S.current = S.history[i].result;
    S.justCalc = true;
    updateDisplay();
}

function clearHistory() {
    S.history = [];
    localStorage.setItem('calcHistory', '[]');
    renderHistory();
    showNotif('History cleared');
}

// ================================================================
// MODE
// ================================================================
function setMode(mode) {
    S.mode = mode;
    ['standard','scientific','history'].forEach(m => {
        document.getElementById(`tab-${m}`).classList.toggle('active', m===mode);
        document.getElementById(`buttons-${m}`).style.display = m===mode ? (m==='scientific'?'grid':m==='standard'?'grid':'block') : 'none';
    });
    if (mode === 'history') renderHistory();
}

// ================================================================
// GRAPHING
// ================================================================
const COLORS = ['#4facfe','#f953c6','#43e97b','#fa8231','#a29bfe','#fd79a8'];

function plotGraph() {
    const input = document.getElementById('graphInput').value.trim();
    if (!input) return;

    const xMin = parseFloat(document.getElementById('xMin').value) || -10;
    const xMax = parseFloat(document.getElementById('xMax').value) || 10;

    if (S.graphFunctions.length >= 6) {
        showNotif('Max 6 functions. Clear some first.', 'warn');
        return;
    }

    const color = COLORS[S.graphFunctions.length % COLORS.length];
    S.graphFunctions.push({ expr: input, color });
    document.getElementById('graphInput').value = '';
    S.graphCount++;
    localStorage.setItem('graphCount', S.graphCount);
    renderGraph(xMin, xMax);
    renderGraphFnList();
    updateStats();
}

function quickPlot(expr) {
    document.getElementById('graphInput').value = expr;
    plotGraph();
}

function parseExpr(expr, x) {
    // Safe math expression parser
    let e = expr
        .replace(/\^/g, '**')
        .replace(/sin\(/g, 'Math.sin(')
        .replace(/cos\(/g, 'Math.cos(')
        .replace(/tan\(/g, 'Math.tan(')
        .replace(/sqrt\(/g, 'Math.sqrt(')
        .replace(/log\(/g, 'Math.log10(')
        .replace(/ln\(/g, 'Math.log(')
        .replace(/abs\(/g, 'Math.abs(')
        .replace(/pi/g, 'Math.PI')
        .replace(/π/g, 'Math.PI')
        .replace(/e(?![a-zA-Z])/g, 'Math.E');
    try {
        // eslint-disable-next-line no-new-func
        return Function('x', `"use strict"; return (${e})`)(x);
    } catch { return NaN; }
}

function renderGraph(xMin, xMax) {
    const canvas = document.getElementById('graphCanvas');
    const ctx = canvas.getContext('2d');

    const steps = 300;
    const step = (xMax - xMin) / steps;
    const labels = [];
    const datasets = S.graphFunctions.map(fn => {
        const data = [];
        for (let i = 0; i <= steps; i++) {
            const x = xMin + i * step;
            if (i === 0) labels.push(x.toFixed(1));
            const y = parseExpr(fn.expr, x);
            data.push({ x, y: isFinite(y) ? y : null });
        }
        return {
            label: `y = ${fn.expr}`,
            data,
            borderColor: fn.color,
            backgroundColor: fn.color + '22',
            borderWidth: 2,
            pointRadius: 0,
            tension: 0.2,
            spanGaps: false
        };
    });

    if (S.chartInstance) S.chartInstance.destroy();

    S.chartInstance = new Chart(ctx, {
        type: 'line',
        data: { datasets },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            animation: { duration: 400 },
            scales: {
                x: {
                    type: 'linear',
                    min: xMin,
                    max: xMax,
                    grid: { color: 'rgba(255,255,255,0.08)' },
                    ticks: { color: 'rgba(255,255,255,0.5)', maxTicksLimit: 8 }
                },
                y: {
                    grid: { color: 'rgba(255,255,255,0.08)' },
                    ticks: { color: 'rgba(255,255,255,0.5)', maxTicksLimit: 8 }
                }
            },
            plugins: {
                legend: {
                    display: false
                },
                tooltip: {
                    mode: 'index',
                    intersect: false,
                    backgroundColor: 'rgba(20,20,50,0.9)',
                    titleColor: 'rgba(255,255,255,0.8)',
                    bodyColor: 'rgba(255,255,255,0.6)'
                }
            }
        }
    });
}

function renderGraphFnList() {
    const list = document.getElementById('graphFnList');
    list.innerHTML = S.graphFunctions.map((fn, i) => `
        <div class="graph-fn-item">
            <div class="fn-color-dot" style="background:${fn.color}"></div>
            <div class="fn-label">y = ${fn.expr}</div>
            <button class="fn-remove" onclick="removeGraphFn(${i})">✕</button>
        </div>`).join('');
}

function removeGraphFn(i) {
    S.graphFunctions.splice(i, 1);
    const xMin = parseFloat(document.getElementById('xMin').value) || -10;
    const xMax = parseFloat(document.getElementById('xMax').value) || 10;
    if (S.graphFunctions.length > 0) renderGraph(xMin, xMax);
    else if (S.chartInstance) { S.chartInstance.destroy(); S.chartInstance = null; }
    renderGraphFnList();
}

function clearGraph() {
    S.graphFunctions = [];
    if (S.chartInstance) { S.chartInstance.destroy(); S.chartInstance = null; }
    renderGraphFnList();
    showNotif('Graph cleared');
}

// ================================================================
// UNIT CONVERTER
// ================================================================
const CONVERTERS = {
    length: {
        units: ['Meter','Kilometer','Centimeter','Millimeter','Mile','Yard','Foot','Inch','Nautical Mile'],
        base: { Meter:1, Kilometer:0.001, Centimeter:100, Millimeter:1000, Mile:0.000621371, Yard:1.09361, Foot:3.28084, Inch:39.3701, 'Nautical Mile':0.000539957 }
    },
    weight: {
        units: ['Kilogram','Gram','Milligram','Pound','Ounce','Ton','Stone'],
        base: { Kilogram:1, Gram:1000, Milligram:1e6, Pound:2.20462, Ounce:35.274, Ton:0.001, Stone:0.157473 }
    },
    temp: {
        units: ['Celsius','Fahrenheit','Kelvin'],
        base: null // handled specially
    },
    area: {
        units: ['Square Meter','Square Kilometer','Square Mile','Acre','Hectare','Square Foot','Square Inch'],
        base: { 'Square Meter':1, 'Square Kilometer':1e-6, 'Square Mile':3.861e-7, Acre:0.000247105, Hectare:0.0001, 'Square Foot':10.7639, 'Square Inch':1550.0031 }
    },
    speed: {
        units: ['m/s','km/h','mph','Knot','ft/s'],
        base: { 'm/s':1, 'km/h':3.6, 'mph':2.23694, 'Knot':1.94384, 'ft/s':3.28084 }
    },
    data: {
        units: ['Byte','Kilobyte','Megabyte','Gigabyte','Terabyte','Bit'],
        base: { Byte:1, Kilobyte:1/1024, Megabyte:1/1048576, Gigabyte:1/1073741824, Terabyte:1/1099511627776, Bit:8 }
    }
};

function setConverter(type, btn) {
    S.converterType = type;
    document.querySelectorAll('.converter-tab').forEach(b => b.classList.remove('active'));
    if (btn) btn.classList.add('active');
    populateConverterSelects();
    doConvert();
}

function populateConverterSelects() {
    const conv = CONVERTERS[S.converterType];
    const from = document.getElementById('convFrom');
    const to = document.getElementById('convTo');
    const opts = conv.units.map(u => `<option value="${u}">${u}</option>`).join('');
    from.innerHTML = opts;
    to.innerHTML = opts;
    if (conv.units.length > 1) to.selectedIndex = 1;
}

function doConvert() {
    const val = parseFloat(document.getElementById('convInput').value);
    const from = document.getElementById('convFrom').value;
    const to = document.getElementById('convTo').value;
    if (isNaN(val)) { document.getElementById('convResult').textContent = '—'; return; }

    let result;
    if (S.converterType === 'temp') {
        result = convertTemp(val, from, to);
    } else {
        const base = CONVERTERS[S.converterType].base;
        const inBase = val / base[from];
        result = inBase * base[to];
    }

    const fmt = Math.abs(result) < 0.001 || Math.abs(result) > 1e9
        ? result.toExponential(4)
        : parseFloat(result.toPrecision(8)).toString();

    document.getElementById('convResult').textContent = fmt;
    document.getElementById('convExpr').textContent = `${val} ${from} =`;
}

function convertTemp(val, from, to) {
    let celsius;
    if (from === 'Celsius') celsius = val;
    else if (from === 'Fahrenheit') celsius = (val-32)*5/9;
    else celsius = val - 273.15;

    if (to === 'Celsius') return celsius;
    if (to === 'Fahrenheit') return celsius*9/5+32;
    return celsius + 273.15;
}

function copyConvResult() {
    const v = document.getElementById('convResult').textContent;
    navigator.clipboard.writeText(v).then(() => showNotif('Copied: ' + v));
}

// ================================================================
// THEMES
// ================================================================
function applyTheme(theme) {
    S.theme = theme;
    document.body.setAttribute('data-theme', theme);
    localStorage.setItem('calcTheme', theme);

    document.querySelectorAll('.theme-card').forEach(c => c.classList.remove('active'));
    const card = document.getElementById(`theme-${theme}`);
    if (card) card.classList.add('active');

    showNotif(`Theme: ${theme.charAt(0).toUpperCase()+theme.slice(1)}`);
