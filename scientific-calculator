        .pricing-cards {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 16px;
        }

        .pricing-card {
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border-color);
            border-radius: 14px;
            padding: 16px;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
        }

        .pricing-card.featured {
            border-color: var(--accent);
            background: rgba(79,172,254,0.1);
        }

        .pricing-card .price {
            font-size: 26px;
            font-weight: 700;
            color: var(--text-primary);
        }

        .pricing-card .period {
            font-size: 12px;
            color: var(--text-secondary);
        }

        .pricing-card .plan-name {
            font-size: 13px;
            font-weight: 600;
            margin-top: 6px;
            color: var(--accent);
        }

        .purchase-btn {
            width: 100%;
            padding: 14px;
            background: var(--btn-equals-bg);
            border: none;
            border-radius: 12px;
            color: #fff;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        /* STATS BAR */
        .stats-bar {
            display: flex;
            gap: 12px;
            padding: 10px 0;
            flex-wrap: wrap;
        }

        .stat-item {
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 8px 14px;
            text-align: center;
            flex: 1;
            min-width: 80px;
        }

        .stat-value {
            font-size: 20px;
            font-weight: 700;
            color: var(--accent);
        }

        .stat-label {
            font-size: 10px;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* FOOTER */
        .app-footer {
            text-align: center;
            padding: 16px;
            font-size: 12px;
            color: var(--text-secondary);
            border-top: 1px solid var(--border-color);
            background: rgba(0,0,0,0.2);
        }

        .footer-links {
            display: flex;
            gap: 16px;
            justify-content: center;
            margin-top: 8px;
        }

        .footer-link {
            color: var(--accent);
            text-decoration: none;
            font-size: 12px;
        }

        /* ANIMATIONS */
        @keyframes shake {
            0%,100% { transform: translateX(0); }
            20% { transform: translateX(-8px); }
            40% { transform: translateX(8px); }
            60% { transform: translateX(-4px); }
            80% { transform: translateX(4px); }
        }

        .shake { animation: shake 0.4s ease; }

        .ripple {
            position: absolute;
            border-radius: 50%;
            background: rgba(255,255,255,0.25);
            transform: scale(0);
            animation: rippleAnim 0.5s linear;
            pointer-events: none;
        }

        @keyframes rippleAnim {
            to { transform: scale(4); opacity: 0; }
        }

        /* SCROLLBAR */
        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 4px; }

        /* RESPONSIVE */
        @media (max-width: 900px) {
            .calc-area { flex-direction: column; align-items: center; }
            .side-panel { max-width: 440px; width: 100%; }
        }

        @media (max-width: 400px) {
            .btn { height: 50px; font-size: 14px; }
            .btn-function { font-size: 11px; }
            .display-main { font-size: 38px; }
            .pricing-cards { grid-template-columns: 1fr; }
        }

        /* NOTIFICATION */
        .notification {
            position: fixed;
            top: 80px;
            right: 20px;
            background: rgba(20,20,50,0.95);
            border: 1px solid var(--accent);
            border-radius: 12px;
            padding: 12px 18px;
            font-size: 13px;
            color: var(--text-primary);
            z-index: 999;
            animation: notifIn 0.3s ease;
            max-width: 280px;
        }

        @keyframes notifIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
    </style>
</head>
