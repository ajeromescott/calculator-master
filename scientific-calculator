// ================================================================
// STATS
// ================================================================
let sessionTimer;
function updateStats() {
    document.getElementById('statCalcs').textContent = S.calcCount;
    document.getElementById('statGraphs').textContent = S.graphCount;
    const elapsed = Math.floor((Date.now() - S.sessionStart) / 1000);
    const m = Math.floor(elapsed/60).toString().padStart(2,'0');
    const s = (elapsed%60).toString().padStart(2,'0');
    document.getElementById('statSession').textContent = `${m}:${s}`;
}

// ================================================================
// PWA / INSTALL
// ================================================================
window.addEventListener('beforeinstallprompt', (e) => {
    e.preventDefault();
    S.deferredPrompt = e;
    document.getElementById('installBtn').style.display = 'flex';
    setTimeout(() => {
        document.getElementById('installPrompt').classList.add('visible');
    }, 5000);
});

function installApp() {
    if (S.deferredPrompt) {
        S.deferredPrompt.prompt();
        S.deferredPrompt.userChoice.then(r => {
            if (r.outcome === 'accepted') showNotif('ProCalc installed successfully! 🎉');
            S.deferredPrompt = null;
        });
    } else {
        showNotif('To install: tap Share → Add to Home Screen (iOS) or use Chrome menu (Android)');
    }
    dismissInstall();
}

function dismissInstall() {
    document.getElementById('installPrompt').classList.remove('visible');
}

// PWA Manifest
function setupPWA() {
    const manifest = {
        name: 'ProCalc - Scientific Calculator',
        short_name: 'ProCalc',
        description: 'Professional Scientific Calculator with Graphing',
        start_url: '/',
        display: 'standalone',
        background_color: '#0f0c29',
        theme_color: '#302b63',
        icons: [
            { src: 'https://via.placeholder.com/192x192/302b63/ffffff?text=PC', sizes: '192x192', type: 'image/png' },
            { src: 'https://via.placeholder.com/512x512/302b63/ffffff?text=PC', sizes: '512x512', type: 'image/png' }
        ]
    };
    const blob = new Blob([JSON.stringify(manifest)], {type:'application/json'});
    const url = URL.createObjectURL(blob);
    document.getElementById('manifestLink').setAttribute('href', url);

    // Register service worker
    if ('serviceWorker' in navigator) {
        const swCode = `
            const CACHE = 'procalc-v1';
            const ASSETS = ['/'];
            self.addEventListener('install', e => e.waitUntil(caches.open(CACHE).then(c => c.addAll(ASSETS))));
            self.addEventListener('fetch', e => e.respondWith(
                caches.match(e.request).then(r => r || fetch(e.request)).catch(() => caches.match('/'))
            ));
        `;
        const swBlob = new Blob([swCode], {type:'application/javascript'});
        const swUrl = URL.createObjectURL(swBlob);
        navigator.serviceWorker.register(swUrl).catch(() => {});
    }
}

// ================================================================
// MONETIZATION
// ================================================================
function selectPlan(plan) {
    S.selectedPlan = plan;
    document.querySelectorAll('.pricing-card').forEach((c,i) => {
        c.style.borderColor = (i===0&&plan==='monthly')||(i===1&&plan==='yearly')
            ? 'var(--accent)' : 'var(--border-color)';
    });
}

function purchase() {
    // In production: integrate Stripe, PayPal, or App Store billing
    showNotif(`Redirecting to payment for ${S.selectedPlan} plan...`);
    setTimeout(() => {
        closeModal('proModal');
        showNotif('Payment system would launch here. Integrate Stripe or PayPal for real payments.');
    }, 1500);
}

function shareApp() {
    if (navigator.share) {
        navigator.share({
            title: 'ProCalc - Scientific Calculator',
            text: 'Check out this amazing scientific calculator!',
            url: window.location.href
        }).catch(() => {});
    } else {
        navigator.clipboard.writeText(window.location.href)
            .then(() => showNotif('Link copied to clipboard!'));
    }
}

// ================================================================
// MODAL
// ================================================================
function openModal(id) {
    document.getElementById(id).classList.add('open');
}

function closeModal(id) {
    document.getElementById(id).classList.remove('open');
}

// Close modal on overlay click
document.querySelectorAll('.modal-overlay').forEach(el => {
    el.addEventListener('click', function(e) {
        if (e.target === this) this.classList.remove('open');
    });
});

// ================================================================
// NOTIFICATIONS
// ================================================================
function showNotif(msg, type) {
    const notif = document.createElement('div');
    notif.className = 'notification';
    notif.textContent = msg;
    if (type === 'warn') notif.style.borderColor = 'var(--btn-clear-color)';
    document.body.appendChild(notif);
    setTimeout(() => {
        notif.style.animation = 'none';
        notif.style.opacity = '0';
        notif.style.transition = 'opacity 0.3s';
        setTimeout(() => notif.remove(), 300);
    }, 2500);
}

// ================================================================
// RIPPLE
// ================================================================
function ripple(e) {
    if (!e) return;
    const btn = e.currentTarget || e.target;
    if (!btn || !btn.getBoundingClientRect) return;
    const rect = btn.getBoundingClientRect();
    const r = document.createElement('span');
    r.className = 'ripple';
    const size = Math.max(rect.width, rect.height);
    const x = (e.clientX||rect.left+rect.width/2) - rect.left - size/2;
    const y = (e.clientY||rect.top+rect.height/2) - rect.top - size/2;
    r.style.cssText = `width:${size}px;height:${size}px;left:${x}px;top:${y}px`;
    btn.appendChild(r);
    setTimeout(() => r.remove(), 600);
}

// ================================================================
// KEYBOARD
// ================================================================
document.addEventListener('keydown', e => {
    if (e.ctrlKey || e.metaKey) return;
    const k = e.key;
    if (k >= '0' && k <= '9') appendNum(k, {});
    else if (k === '.') appendDec({});
    else if (k === '+') appendOp('+', {});
    else if (k === '-') appendOp('−', {});
    else if (k === '*') appendOp('×', {});
    else if (k === '/') { e.preventDefault(); appendOp('÷', {}); }
    else if (k === 'Enter' || k === '=') calculate({});
    else if (k === 'Backspace') backspace({});
    else if (k === 'Escape') clearAll({});
    else if (k === '%') percentage({});
    else if (k === 's') sciFn('sin', {});
    else if (k === 'c') sciFn('cos', {});
    else if (k === 't') sciFn('tan', {});
    else if (k === 'l') sciFn('log', {});
    else if (k === 'n') sciFn('ln', {});
    else if (k === 'r') sciFn('√', {});
    else if (k === 'p') sciFn('π', {});
});

// ================================================================
// INIT
// ================================================================
function init() {
    // Apply saved theme
    applyTheme(S.theme);

    // Populate converter
    populateConverterSelects();
    doConvert();

    // Render history
    renderHistory();

    // Update display
    updateDisplay();

    // Setup PWA
    setupPWA();

    // Session timer
    sessionTimer = setInterval(updateStats, 1000);

    // Initial graph
    setTimeout(() => {
        quickPlot('sin(x)');
        quickPlot('cos(x)');
    }, 500);

    // Update stats
    document.getElementById('statCalcs').textContent = S.calcCount;
    document.getElementById('statGraphs').textContent = S.graphCount;
}

init();
</script>
