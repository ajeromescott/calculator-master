<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <title>SciCalc | Scientific Calculator</title>
    <style>
        * {
            box-sizing: border-box;
            user-select: none; /* avoid accidental text selection on double-tap */
        }

        body {
            background: linear-gradient(145deg, #1e2a3a 0%, #0f1724 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', 'Roboto', 'Inter', system-ui, -apple-system, 'Helvetica Neue', sans-serif;
            margin: 0;
            padding: 16px;
        }

        /* main card / calculator container */
        .calculator {
            max-width: 550px;
            width: 100%;
            background: rgba(22, 28, 38, 0.85);
            backdrop-filter: blur(2px);
            border-radius: 48px;
            padding: 20px 20px 28px;
            box-shadow: 0 25px 45px rgba(0, 0, 0, 0.4), inset 0 1px 1px rgba(255,255,255,0.1);
            transition: all 0.2s ease;
        }

        /* display area */
        .display {
            background: #0a0e14;
            border-radius: 32px;
            padding: 20px 24px;
            margin-bottom: 24px;
            box-shadow: inset 0 4px 8px rgba(0,0,0,0.4), 0 1px 0 rgba(255,255,255,0.05);
        }

        .expression {
            font-size: 1.2rem;
            color: #8ea1b5;
            min-height: 32px;
            text-align: right;
            font-family: 'Courier New', 'Fira Code', monospace;
            letter-spacing: 0.5px;
            word-wrap: break-word;
            word-break: break-all;
        }

        .result {
            font-size: 2.8rem;
            font-weight: 600;
            color: #f0f3f8;
            text-align: right;
            font-family: 'Segoe UI', monospace;
            word-wrap: break-word;
            word-break: break-word;
            line-height: 1.2;
            margin-top: 8px;
            letter-spacing: -0.5px;
        }

        /* button grid */
        .button-grid {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 10px;
        }

        /* general button styling */
        button {
            background: #1e293b;
            border: none;
            padding: 14px 0;
            border-radius: 28px;
            font-size: 1.2rem;
            font-weight: 500;
            color: #eef2ff;
            cursor: pointer;
            transition: 0.1s linear;
            box-shadow: 0 3px 5px rgba(0,0,0,0.2);
            font-family: inherit;
            touch-action: manipulation;
        }

        button:active {
            transform: scale(0.96);
            background: #0f172a;
            box-shadow: 0 1px 2px black;
        }

        /* special button types */
        .fn-btn {
            background: #2d3a4b;
            color: #cbd5e6;
            font-size: 1rem;
        }

        .op-btn {
            background: #f97316;
            color: white;
            font-weight: bold;
            font-size: 1.3rem;
            box-shadow: 0 3px 6px rgba(249,115,22,0.3);
        }

        .eq-btn {
            background: #10b981;
            color: white;
            font-size: 1.5rem;
            font-weight: bold;
            box-shadow: 0 3px 6px rgba(16,185,129,0.3);
        }

        .clear-btn {
            background: #ef4444;
            color: white;
            font-weight: bold;
        }

        .inv-btn {
            background: #334155;
            font-size: 0.9rem;
        }

        /* second function indicator */
        .second-mode {
            background: #475569;
            box-shadow: inset 0 0 0 2px #facc15;
        }

        /* responsive: for smaller devices reduce padding & font sizes */
        @media (max-width: 550px) {
            .calculator {
                padding: 14px 16px 22px;
            }
            .button-grid {
                gap: 8px;
            }
            button {
                padding: 10px 0;
                font-size: 1rem;
            }
            .result {
                font-size: 2rem;
            }
            .expression {
                font-size: 0.9rem;
            }
            .fn-btn {
                font-size: 0.85rem;
            }
            .op-btn {
                font-size: 1.2rem;
            }
        }

        @media (max-width: 460px) {
            .button-grid {
                gap: 6px;
            }
            button {
                padding: 9px 0;
                font-size: 0.9rem;
                border-radius: 24px;
            }
            .fn-btn {
                font-size: 0.75rem;
            }
        }

        /* subtle indicator for active shift */
        .shift-badge {
            display: inline-block;
            font-size: 0.7rem;
            background: #facc15;
            color: #0f1724;
            border-radius: 20px;
            padding: 2px 8px;
            margin-left: 12px;
            font-weight: bold;
        }

        .display-header {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 8px;
        }
    </style>
</head>
<body>
<div class="calculator">
    <div class="display">
        <div class="display-header">
            <div class="expression" id="expressionDisplay">0</div>
            <div id="shiftIndicator" style="display: none;"><span class="shift-badge">2nd</span></div>
        </div>
        <div class="result" id="resultDisplay">0</div>
    </div>
    <div class="button-grid" id="buttonsContainer">
        <!-- buttons will be generated by js for clarity, but we'll define layout in JS to keep html minimal -->
    </div>
</div>

<script>
    // ---------- Scientific Calculator Core ----------
    // states
    let currentExpression = "0";       // what user sees in the expression line
    let currentResult = "0";           // last computed value shown in big display
    let lastOperator = null;            // not heavily used, but for consistency
    let waitingForOperand = false;      // after "=" or error, next digit starts new expression
    let shiftActive = false;             // 2nd function toggle (sin⁻¹, cos⁻¹, tan⁻¹, sqrt, etc)
    
    // DOM elements
    const exprDiv = document.getElementById("expressionDisplay");
    const resultDiv = document.getElementById("resultDisplay");
    const shiftIndicatorSpan = document.getElementById("shiftIndicator");
    
    // Helper: update UI from currentExpression & currentResult
    function updateDisplay() {
        exprDiv.innerText = currentExpression === "" ? "0" : currentExpression;
        resultDiv.innerText = currentResult;
    }
    
    // safe evaluate using Function constructor (only basic + scientific functions)
    // we will build a sanitized evaluator that supports: + - * / % **, sin, cos, tan, asin, acos, atan, sqrt, log, ln, exp, pi, e, rad/deg? For simplicity we treat trig in radians (standard)
    // also support powers ^ (converted to **)
    // Also factorial, power10, etc. We'll implement via pre-processing + native Math.
    
    function evaluateExpression(expr) {
        // Replace ^ with ** for exponentiation
        let processed = expr.replace(/\^/g, '**');
        // Replace scientific constants: pi, e
        processed = processed.replace(/π/g, 'PI');
        processed = processed.replace(/e\b/g, 'E');
        // handle factorial: n! (only integer factorial for n>=0)
        // factorial replacement: we will parse ! after numbers or parentheses
        // For simplicity: replace x! with factorial(x) using custom function
        processed = processed.replace(/(\d+(?:\.\d+)?|\)|π|E|PI)!/g, (match, numOrGroup) => {
            let number = numOrGroup;
            // handle parentheses groups: e.g., (2+3)! -> need to evaluate subexpr? but factorial is postfix.
            // For scientific calc robustness: we restrict factorial to numbers or simple values. We'll evaluate on the fly.
            if (number === ')') return match; // skip complex, but better evaluate inside later? safer to use custom parse.
            // we'll create a safer approach: replace N! with fact(N) where fact is defined.
            return `fact(${number})`;
        });
        
        // Also support percent? We'll keep classic: 50% -> 0.5? but scientific usually explicit. I'll add simple % as divide by 100 on preceding number.
        // handle % of number: e.g., 50% => 0.5 , but we can replace /100 pattern.
        processed = processed.replace(/(\d+(?:\.\d+)?)%/g, '($1/100)');
        
        // define helper functions inside evaluation context
        const fact = (n) => {
            let num = Number(n);
            if (isNaN(num) || !Number.isInteger(num) || num < 0) return NaN;
            if (num === 0 || num === 1) return 1;
            let res = 1;
            for (let i = 2; i <= num; i++) res *= i;
            return res;
        };
        
        // trigonometric helpers (degrees / radians? In scientific we default rad, but can add deg toggle? For simplicity all trig in radians)
        // add extra functions: log10, ln, sqrt, cbrt, asin, acos, atan, sinh, cosh, tanh, asinh, etc? Provide common ones.
        // However to keep UI reasonable, we map:
        // sin, cos, tan, asin, acos, atan, sinh, cosh, tanh, sqrt, cbrt, log (log10), ln (natural log), exp.
        // And second functions: arcsin, arccos, arctan, x^y (already have ^), 10^x, e^x, x², x³, 1/x, |x|, etc.
        // We'll build safe evaluator with math context.
        
        const safeEval = (expression) => {
            // define math context
            const mathContext = {
                PI: Math.PI,
                E: Math.E,
                sin: (x) => Math.sin(x),
                cos: (x) => Math.cos(x),
                tan: (x) => Math.tan(x),
                asin: (x) => Math.asin(x),
                acos: (x) => Math.acos(x),
                atan: (x) => Math.atan(x),
                sinh: (x) => Math.sinh(x),
                cosh: (x) => Math.cosh(x),
                tanh: (x) => Math.tanh(x),
                asinh: (x) => Math.asinh(x),
                acosh: (x) => Math.acosh(x),
                atanh: (x) => Math.atanh(x),
                sqrt: (x) => Math.sqrt(x),
                cbrt: (x) => Math.cbrt(x),
                log: (x) => Math.log10(x),      // log10
                ln: (x) => Math.log(x),         // natural log
                exp: (x) => Math.exp(x),
                abs: (x) => Math.abs(x),
                floor: (x) => Math.floor(x),
                ceil: (x) => Math.ceil(x),
                round: (x) => Math.round(x),
                fact: fact,
                // helper for power:
                pow: (a,b) => Math.pow(a,b)
            };
            
            // Use Function with with? not secure, but we can use a new Function and inject variables
            // Safer: apply js evaluation after variable replacement.
            // Use proxy or Function: we define all as local variables in scope.
            const keys = Object.keys(mathContext);
            const values = keys.map(k => mathContext[k]);
            try {
                // Create function that uses those symbols
                const evaluator = new Function(...keys, `return (${expression});`);
                const result = evaluator(...values);
                if (isNaN(result) || !isFinite(result)) throw new Error("Math Error");
                return result;
            } catch (err) {
                console.warn(err);
                return NaN;
            }
        };
        
        try {
            let finalExpr = processed;
            // additional safety: replace any consecutive operators? not necessary.
            let computed = safeEval(finalExpr);
            if (isNaN(computed)) return "Error";
            // round to avoid floating noise, but keep high precision
            if (Math.abs(computed) > 1e12) return computed.toExponential(8);
            return parseFloat(computed.toFixed(10)).toString();
        } catch (e) {
            return "Error";
        }
    }
    
    // recompute current expression fully
    function computeAndUpdate() {
        if (currentExpression === "" || currentExpression === "Error") {
            currentResult = "0";
            updateDisplay();
            return;
        }
        let evalResult = evaluateExpression(currentExpression);
        if (evalResult === "Error") {
            currentResult = "Error";
            resultDiv.innerText = "Error";
            exprDiv.innerText = currentExpression;
            waitingForOperand = true;
        } else {
            currentResult = evalResult;
            waitingForOperand = true; // after compute, next digit starts fresh
            updateDisplay();
        }
    }
    
    // append token to expression
    function appendToExpression(value) {
        if (waitingForOperand && !isOperator(value) && value !== '=' && value !== ')' && value !== '(' && !isFunctionCommand(value)) {
            // after result, start fresh expression
            currentExpression = (value === '.' ? '0.' : value);
            waitingForOperand = false;
        } else if (currentExpression === "0" && !isOperator(value) && value !== '.' && !isFunctionCommand(value) && value !== '(') {
            currentExpression = value;
        } else if (currentExpression === "Error") {
            currentExpression = value;
            waitingForOperand = false;
        } else {
            currentExpression += value;
        }
        // clean potential duplicates: avoid multiple leading zeros but fine
        updateDisplay();
        // compute live? scientific often update on '=', but we can evaluate on equals only, but also nice to show when pressing '='
        // but we also compute on equals; no need realtime eval.
    }
    
    function isOperator(val) {
        return ['+', '-', '*', '/', '%', '^'].includes(val);
    }
    
    function isFunctionCommand(val) {
        // these are function names ending with '('
        return /^[a-z]+\($/i.test(val);
    }
    
    // apply unary operation (like sqrt, sin, etc) depending on shift
    function applyFunction(funcName) {
        let activeFunc = funcName;
        if (shiftActive) {
            // shift mapping: sin->asin, cos->acos, tan->atan, sqrt->cbrt, ln->exp, log->10^, x² -> x³ ? we map systematically
            const shiftMap = {
                'sin': 'asin', 'cos': 'acos', 'tan': 'atan',
                'sin(': 'asin(', 'cos(': 'acos(', 'tan(': 'atan(',
                'sqrt': 'cbrt', 'sqrt(': 'cbrt(',
                'ln': 'exp', 'ln(': 'exp(',
                'log': '10^',    // we treat as 10^( ... )
                'x²': 'x³',      // custom
                'xʸ': 'x^y'      // but x^y already, handled via operator
            };
            if (shiftMap[funcName]) activeFunc = shiftMap[funcName];
            else if (funcName === '1/x') activeFunc = 'abs'; // but we handle shift differently for inv.
            // custom: for 1/x second = |x|? but we will handle in mapping before insertion.
        }
        
        // handle special cases: 10^ for shift of log
        if (activeFunc === '10^') {
            appendToExpression('10^(');
            return;
        }
        if (activeFunc === 'x³') {
            // cube the current operand: we can take the last number or whole expression between parentheses? best: wrap last value? simpler: insert ^3 on current token
            // We'll insert ^3 at end of expression but smart: insert ( currentExpression )^3? Overkill, just append '^3'
            appendToExpression('^3');
            return;
        }
        if (activeFunc === 'x²') {
            appendToExpression('^2');
            return;
        }
        if (activeFunc === '1/x') {
            appendToExpression('^(-1)');
            return;
        }
        if (activeFunc === '|x|') {
            appendToExpression('abs(');
            return;
        }
        if (activeFunc === 'floor') {
            appendToExpression('floor(');
            return;
        }
        if (activeFunc === 'ceil') {
            appendToExpression('ceil(');
            return;
        }
        if (activeFunc === 'round') {
            appendToExpression('round(');
            return;
        }
        if (activeFunc === 'fact') {
            appendToExpression('!');
            return;
        }
        // standard functions with parentheses
        let finalFunc = activeFunc.endsWith('(') ? activeFunc : activeFunc + '(';
        appendToExpression(finalFunc);
    }
    
    // clear all
    function clearAll() {
        currentExpression = "0";
        currentResult = "0";
        waitingForOperand = false;
        shiftActive = false;
        updateShiftUI();
        updateDisplay();
    }
    
    // backspace
    function backspace() {
        if (currentExpression === "Error") {
            clearAll();
            return;
        }
        if (currentExpression.length === 1 || (currentExpression === "0")) {
            currentExpression = "0";
        } else {
            currentExpression = currentExpression.slice(0, -1);
            if (currentExpression === "") currentExpression = "0";
        }
        updateDisplay();
        waitingForOperand = false;
    }
    
    // equals
    function evaluateEquals() {
        if (currentExpression === "" || currentExpression === "Error") return;
        let evalResult = evaluateExpression(currentExpression);
        if (evalResult === "Error") {
            currentResult = "Error";
            currentExpression = "Error";
        } else {
            currentResult = evalResult;
            currentExpression = evalResult;   // after equals, new expr = result
            waitingForOperand = true;
        }
        shiftActive = false;
        updateShiftUI();
        updateDisplay();
    }
    
    // Toggle shift mode
    function toggleShift() {
        shiftActive = !shiftActive;
        updateShiftUI();
    }
    
    function updateShiftUI() {
        if (shiftActive) {
            shiftIndicatorSpan.style.display = "inline-flex";
        } else {
            shiftIndicatorSpan.style.display = "none";
        }
        // also update buttons visual? change class on button containers dynamically? We'll just reapply style on active buttons
        // additional visual on '2nd' button itself
        const invBtn = document.getElementById('invButton');
        if (invBtn) {
            if (shiftActive) invBtn.classList.add('second-mode');
            else invBtn.classList.remove('second-mode');
        }
    }
    
    // handle parentheses
    function addParenthesis() {
        appendToExpression('(');
    }
    
    function closeParenthesis() {
        appendToExpression(')');
    }
    
    // ----- Build dynamic buttons (maintain responsiveness and layout) -----
    function buildCalculatorUI() {
        const container = document.getElementById("buttonsContainer");
        // Define button sets: each object {label, action, type, value?}
        const buttons = [
            // row1: 2nd, ( , ), C, ⌫, ÷ (/)
            { label: "2nd", action: "shift", class: "fn-btn inv-btn", id: "invButton" },
            { label: "(", action: "parenOpen", class: "fn-btn" },
            { label: ")", action: "parenClose", class: "fn-btn" },
            { label: "C", action: "clear", class: "clear-btn" },
            { label: "⌫", action: "backspace", class: "fn-btn" },
            { label: "÷", action: "operator", value: "/", class: "op-btn" },
            // row2: sin, cos, tan, ln, log, ×
            { label: "sin", action: "func", func: "sin", class: "fn-btn" },
            { label: "cos", action: "func", func: "cos", class: "fn-btn" },
            { label: "tan", action: "func", func: "tan", class: "fn-btn" },
            { label: "ln", action: "func", func: "ln", class: "fn-btn" },
            { label: "log", action: "func", func: "log", class: "fn-btn" },
            { label: "×", action: "operator", value: "*", class: "op-btn" },
            // row3: asin / second layer? but mapped by shift; show x², x³, √, ∛, xʸ, - (minus)
            { label: "x²", action: "func", func: "x²", class: "fn-btn" },
            { label: "x³", action: "func", func: "x³", class: "fn-btn" },
            { label: "√", action: "func", func: "sqrt", class: "fn-btn" },
            { label: "∛", action: "func", func: "cbrt", class: "fn-btn" },
            { label: "xʸ", action: "operator", value: "^", class: "fn-btn" },
            { label: "−", action: "operator", value: "-", class: "op-btn" },
            // row4: 1/x, |x|, π, e, n!, + (plus)
            { label: "1/x", action: "func", func: "1/x", class: "fn-btn" },
            { label: "|x|", action: "func", func: "|x|", class: "fn-btn" },
            { label: "π", action: "constant", value: "π", class: "fn-btn" },
            { label: "e", action: "constant", value: "e", class: "fn-btn" },
            { label: "n!", action: "func", func: "fact", class: "fn-btn" },
            { label: "+", action: "operator", value: "+", class: "op-btn" },
            // row5: 7,8,9, (, ), % ,
            { label: "7", action: "digit", value: "7", class: "" },
            { label: "8", action: "digit", value: "8", class: "" },
            { label: "9", action: "digit", value: "9", class: "" },
            { label: "(", action: "parenOpen", class: "fn-btn" },
            { label: ")", action: "parenClose", class: "fn-btn" },
            { label: "%", action: "operator", value: "%", class: "fn-btn" },
            // row6: 4,5,6, floor, ceil, round (extra scientific)
            { label: "4", action: "digit", value: "4", class: "" },
            { label: "5", action: "digit", value: "5", class: "" },
            { label: "6", action: "digit", value: "6", class: "" },
            { label: "floor", action: "func", func: "floor", class: "fn-btn" },
            { label: "ceil", action: "func", func: "ceil", class: "fn-btn" },
            { label: "round", action: "func", func: "round", class: "fn-btn" },
            // row7: 1,2,3, asin, acos, atan (on shift these show arc versions, but same button label)
            { label: "1", action: "digit", value: "1", class: "" },
            { label: "2", action: "digit", value: "2", class: "" },
            { label: "3", action: "digit", value: "3", class: "" },
            { label: "asin", action: "func", func: "asin", class: "fn-btn" },
            { label: "acos", action: "func", func: "acos", class: "fn-btn" },
            { label: "atan", action: "func", func: "atan", class: "fn-btn" },
            // row8: 0, ., (-) , exp, sinh, = (equal)
            { label: "0", action: "digit", value: "0", class: "" },
            { label: ".", action: "digit", value: ".", class: "" },
            { label: "(-)", action: "negate", class: "fn-btn" },
            { label: "exp", action: "func", func: "exp", class: "fn-btn" },
            { label: "sinh", action: "func", func: "sinh", class: "fn-btn" },
            { label: "=", action: "equal", class: "eq-btn" }
        ];
        
        container.innerHTML = "";
        buttons.forEach(btn => {
            const buttonEl = document.createElement("button");
            buttonEl.innerText = btn.label;
            if (btn.class) buttonEl.className = btn.class;
            else buttonEl.className = "";
            if (btn.id) buttonEl.id = btn.id;
            
            buttonEl.addEventListener("click", (e) => {
                e.preventDefault();
                switch (btn.action) {
                    case "digit": appendToExpression(btn.value); break;
                    case "operator": appendToExpression(btn.value); break;
                    case "constant": appendToExpression(btn.value); break;
                    case "func": applyFunction(btn.func); break;
                    case "shift": toggleShift(); break;
                    case "clear": clearAll(); break;
                    case "backspace": backspace(); break;
                    case "parenOpen": addParenthesis(); break;
                    case "parenClose": closeParenthesis(); break;
                    case "equal": evaluateEquals(); break;
                    case "negate": 
                        if (currentExpression !== "Error") {
                            if (/^[0-9].*/.test(currentExpression) || currentExpression === "0") {
                                if (currentExpression.startsWith('-')) currentExpression = currentExpression.slice(1);
                                else currentExpression = '-' + currentExpression;
                                updateDisplay();
                            } else {
                                appendToExpression('(-');
                            }
                        }
                        break;
                    default: break;
                }
                // after any action, if shift is not persistent for long, but we keep shift until manually toggled off.
            });
            container.appendChild(buttonEl);
        });
    }
    
    // initial reset and UI building
    function init() {
        buildCalculatorUI();
        clearAll();
        updateShiftUI();
    }
    
    init();
</script>
</body>
</html>
