<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
    <title>ProCalc - Scientific Calculator</title>
    
    <!-- PWA Meta Tags -->
    <meta name="description" content="Professional Scientific Calculator with Graphing, Themes, and More">
    <meta name="theme-color" content="#302b63">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="ProCalc">
    <link rel="manifest" href="#" id="manifestLink">
    
    <!-- Graph Library -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <!-- AdSense Placeholder -->
    <style>
        /* ============================================================
           CSS VARIABLES & THEMES
        ============================================================ */
        :root {
            --bg-gradient: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            --calc-bg: rgba(255,255,255,0.05);
            --display-bg: rgba(0,0,0,0.3);
            --btn-number-bg: rgba(255,255,255,0.08);
            --btn-number-color: #ffffff;
            --btn-operator-bg: rgba(100,160,255,0.15);
            --btn-operator-color: #7eb8ff;
            --btn-function-bg: rgba(255,255,255,0.05);
            --btn-function-color: rgba(200,200,255,0.9);
            --btn-equals-bg: linear-gradient(135deg, #4facfe, #00f2fe);
            --btn-clear-bg: rgba(255,80,80,0.15);
            --btn-clear-color: #ff7070;
            --btn-special-bg: rgba(255,200,100,0.1);
            --btn-special-color: rgba(255,200,150,0.9);
            --btn-memory-bg: rgba(100,255,200,0.1);
            --btn-memory-color: rgba(100,255,200,0.9);
            --text-primary: #ffffff;
            --text-secondary: rgba(255,255,255,0.5);
            --border-color: rgba(255,255,255,0.1);
            --accent: #4facfe;
            --shadow: 0 25px 50px rgba(0,0,0,0.5);
        }

        /* LIGHT THEME */
        [data-theme="light"] {
            --bg-gradient: linear-gradient(135deg, #e8ecf4, #d5dde8, #c8d4e0);
            --calc-bg: rgba(255,255,255,0.9);
            --display-bg: rgba(240,244,255,0.95);
            --btn-number-bg: rgba(255,255,255,0.9);
            --btn-number-color: #2c3e50;
            --btn-operator-bg: rgba(52,152,219,0.15);
            --btn-operator-color: #2980b9;
            --btn-function-bg: rgba(200,210,230,0.6);
            --btn-function-color: #34495e;
            --btn-equals-bg: linear-gradient(135deg, #3498db, #2980b9);
            --btn-clear-bg: rgba(231,76,60,0.15);
            --btn-clear-color: #e74c3c;
            --btn-special-bg: rgba(241,196,15,0.15);
            --btn-special-color: #d4a017;
            --btn-memory-bg: rgba(46,204,113,0.15);
            --btn-memory-color: #27ae60;
            --text-primary: #2c3e50;
            --text-secondary: rgba(44,62,80,0.6);
            --border-color: rgba(0,0,0,0.08);
            --accent: #3498db;
            --shadow: 0 25px 50px rgba(0,0,0,0.15);
        }

        /* NEON THEME */
        [data-theme="neon"] {
            --bg-gradient: linear-gradient(135deg, #000000, #0a0a0a, #050505);
            --calc-bg: rgba(0,255,100,0.03);
            --display-bg: rgba(0,0,0,0.8);
            --btn-number-bg: rgba(0,255,100,0.05);
            --btn-number-color: #00ff64;
            --btn-operator-bg: rgba(0,200,255,0.1);
            --btn-operator-color: #00c8ff;
            --btn-function-bg: rgba(255,0,200,0.05);
            --btn-function-color: #ff00c8;
            --btn-equals-bg: linear-gradient(135deg, #00ff64, #00c8ff);
            --btn-clear-bg: rgba(255,50,50,0.1);
            --btn-clear-color: #ff3232;
            --btn-special-bg: rgba(255,200,0,0.05);
            --btn-special-color: #ffc800;
            --btn-memory-bg: rgba(200,0,255,0.1);
            --btn-memory-color: #c800ff;
            --text-primary: #00ff64;
            --text-secondary: rgba(0,255,100,0.5);
            --border-color: rgba(0,255,100,0.15);
            --accent: #00ff64;
            --shadow: 0 0 50px rgba(0,255,100,0.2);
        }

        /* SUNSET THEME */
        [data-theme="sunset"] {
            --bg-gradient: linear-gradient(135deg, #1a1a2e, #16213e, #0f3460);
            --calc-bg: rgba(255,100,50,0.05);
            --display-bg: rgba(0,0,0,0.4);
            --btn-number-bg: rgba(255,150,100,0.1);
            --btn-number-color: #ffb899;
            --btn-operator-bg: rgba(255,100,50,0.15);
            --btn-operator-color: #ff9966;
            --btn-function-bg: rgba(255,50,100,0.08);
            --btn-function-color: rgba(255,180,150,0.9);
            --btn-equals-bg: linear-gradient(135deg, #f953c6, #b91d73);
            --btn-clear-bg: rgba(255,50,50,0.15);
            --btn-clear-color: #ff6b6b;
            --btn-special-bg: rgba(255,200,50,0.1);
            --btn-special-color: rgba(255,220,150,0.9);
            --btn-memory-bg: rgba(100,200,255,0.1);
            --btn-memory-color: rgba(150,220,255,0.9);
            --text-primary: #ffe0d0;
            --text-secondary: rgba(255,200,150,0.6);
            --border-color: rgba(255,100,50,0.15);
            --accent: #f953c6;
            --shadow: 0 25px 50px rgba(0,0,0,0.6);
        }

        /* OCEAN THEME */
        [data-theme="ocean"] {
            --bg-gradient: linear-gradient(135deg, #000428, #004e92, #000428);
            --calc-bg: rgba(0,150,255,0.05);
            --display-bg: rgba(0,30,80,0.6);
            --btn-number-bg: rgba(0,150,255,0.1);
            --btn-number-color: #a0d8ff;
            --btn-operator-bg: rgba(0,200,200,0.15);
            --btn-operator-color: #00e5e5;
            --btn-function-bg: rgba(0,100,200,0.1);
            --btn-function-color: rgba(150,220,255,0.9);
            --btn-equals-bg: linear-gradient(135deg, #00c6ff, #0072ff);
            --btn-clear-bg: rgba(255,80,120,0.15);
            --btn-clear-color: #ff6090;
            --btn-special-bg: rgba(100,200,255,0.1);
            --btn-special-color: rgba(150,230,255,0.9);
            --btn-memory-bg: rgba(0,255,200,0.1);
            --btn-memory-color: rgba(100,255,200,0.9);
            --text-primary: #d0f0ff;
            --text-secondary: rgba(150,220,255,0.6);
            --border-color: rgba(0,150,255,0.2);
            --accent: #00c6ff;
            --shadow: 0 25px 50px rgba(0,0,0,0.7);
        }

        /* ============================================================
           BASE STYLES
        ============================================================ */
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            min-height: 100vh;
            background: var(--bg-gradient);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: var(--text-primary);
            transition: all 0.4s ease;
            overflow-x: hidden;
        }

        /* ============================================================
           APP LAYOUT
        ============================================================ */
        .app-container {
            display: grid;
            grid-template-rows: auto 1fr auto;
            min-height: 100vh;
        }

        /* TOP NAV */
        .top-nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 20px;
            background: rgba(0,0,0,0.2);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border-color);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .app-logo {
            font-size: 20px;
            font-weight: 700;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .app-logo .logo-icon {
            font-size: 24px;
        }

        .nav-actions {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .nav-btn {
            background: rgba(255,255,255,0.08);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .nav-btn:hover {
            background: rgba(255,255,255,0.15);
        }

        /* MAIN CONTENT */
        .main-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
            gap: 20px;
        }

        /* AD BANNER */
        .ad-banner {
            width: 100%;
            max-width: 728px;
            background: rgba(255,255,255,0.05);
            border: 1px dashed rgba(255,255,255,0.15);
            border-radius: 12px;
            padding: 12px;
            text-align: center;
            font-size: 12px;
            color: var(--text-secondary);
            min-height: 90px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .ad-inner {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
        }

        .ad-label {
            font-size: 10px;
            opacity: 0.5;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* CALCULATOR AREA */
        .calc-area {
            display: flex;
            gap: 20px;
            width: 100%;
            max-width: 1100px;
            align-items: flex-start;
            justify-content: center;
        }

        /* CALCULATOR */
        .calculator-wrapper {
            width: 100%;
            max-width: 440px;
            flex-shrink: 0;
        }

        .calculator {
            background: var(--calc-bg);
            backdrop-filter: blur(20px);
            border-radius: 24px;
            border: 1px solid var(--border-color);
            box-shadow: var(--shadow);
            overflow: hidden;
            transition: all 0.4s ease;
        }

        /* DISPLAY */
        .display {
            padding: 24px 20px 16px;
            background: var(--display-bg);
            min-height: 160px;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            position: relative;
            transition: all 0.3s;
        }

        .display-history {
            font-size: 13px;
            color: var(--text-secondary);
            text-align: right;
            min-height: 18px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .display-expression {
            font-size: 16px;
            color: var(--text-secondary);
            text-align: right;
            min-height: 26px;
            margin-bottom: 6px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .display-main {
            font-size: 48px;
            color: var(--text-primary);
            text-align: right;
            font-weight: 300;
            line-height: 1;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            transition: font-size 0.2s ease, color 0.3s;
        }

        .display-main.small { font-size: 32px; }
        .display-main.xsmall { font-size: 22px; }

        .display-badges {
            position: absolute;
            top: 12px;
            left: 16px;
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
        }

        .badge {
            font-size: 10px;
            padding: 2px 8px;
            border-radius: 4px;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .badge-mem {
            background: rgba(100,200,255,0.2);
            color: rgba(100,200,255,0.9);
            display: none;
        }

        .badge-mem.active { display: block; }

        .badge-angle {
            background: rgba(255,200,100,0.2);
            color: rgba(255,200,100,0.9);
        }

        .badge-pro {
            background: linear-gradient(135deg, var(--accent), transparent);
            color: var(--text-primary);
        }

        /* MODE TOGGLE */
        .mode-bar {
            display: flex;
            padding: 10px 12px 6px;
            gap: 6px;
            background: rgba(0,0,0,0.15);
            overflow-x: auto;
        }

        .mode-bar::-webkit-scrollbar { display: none; }

        .mode-tab {
            flex-shrink: 0;
            padding: 6px 14px;
            background: transparent;
            border: 1px solid var(--border-color);
            border-radius: 20px;
            color: var(--text-secondary);
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
            white-space: nowrap;
        }

        .mode-tab.active {
            background: rgba(100,180,255,0.15);
            border-color: var(--accent);
            color: var(--accent);
        }

        /* BUTTONS */
        .buttons {
            padding: 10px;
            display: grid;
            gap: 7px;
        }

        .buttons.standard-grid { grid-template-columns: repeat(4, 1fr); }
        .buttons.scientific-grid { grid-template-columns: repeat(5, 1fr); }

        .btn {
            height: 56px;
            border: none;
            border-radius: 14px;
            font-size: 16px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.15s ease;
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            user-select: none;
            -webkit-tap-highlight-color: transparent;
            border: 1px solid transparent;
            flex-direction: column;
        }

        .btn:active { transform: scale(0.94); }

        .btn-number {
            background: var(--btn-number-bg);
            color: var(--btn-number-color);
            border-color: var(--border-color);
        }

        .btn-operator {
            background: var(--btn-operator-bg);
            color: var(--btn-operator-color);
        }

        .btn-function {
            background: var(--btn-function-bg);
            color: var(--btn-function-color);
            font-size: 13px;
        }

        .btn-equals {
            background: var(--btn-equals-bg);
            color: #fff;
            font-size: 22px;
            box-shadow: 0 4px 15px rgba(79,172,254,0.3);
        }

        .btn-clear {
            background: var(--btn-clear-bg);
            color: var(--btn-clear-color);
        }

        .btn-special {
            background: var(--btn-special-bg);
            color: var(--btn-special-color);
            font-size: 13px;
        }

        .btn-memory {
            background: var(--btn-memory-bg);
            color: var(--btn-memory-color);
            font-size: 12px;
        }

        .btn::after {
            content: '';
            position: absolute;
            inset: 0;
            background: rgba(255,255,255,0);
            transition: background 0.15s;
        }

        .btn:hover::after { background: rgba(255,255,255,0.08); }
        .btn:active::after { background: rgba(255,255,255,0.15); }

        /* PANELS */
        .side-panel {
            flex: 1;
            max-width: 600px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .panel-card {
            background: var(--calc-bg);
            backdrop-filter: blur(20px);
            border-radius: 20px;
            border: 1px solid var(--border-color);
            overflow: hidden;
            box-shadow: var(--shadow);
            transition: all 0.4s;
        }

        .panel-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 16px;
            background: rgba(0,0,0,0.15);
            border-bottom: 1px solid var(--border-color);
        }

        .panel-title {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .panel-body {
            padding: 16px;
        }

        /* GRAPH PANEL */
        .graph-input-row {
            display: flex;
            gap: 8px;
            margin-bottom: 12px;
            flex-wrap: wrap;
        }

        .graph-input {
            flex: 1;
            min-width: 140px;
            padding: 10px 14px;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            color: var(--text-primary);
            font-size: 14px;
            outline: none;
            transition: border-color 0.2s;
        }

        .graph-input:focus {
            border-color: var(--accent);
        }

        .graph-btn {
            padding: 10px 20px;
            background: var(--btn-equals-bg);
            border: none;
            border-radius: 10px;
            color: #fff;
            font-size: 14px;
            cursor: pointer;
            font-weight: 600;
            transition: opacity 0.2s;
        }

        .graph-btn:hover { opacity: 0.85; }

        .graph-container {
            position: relative;
            background: rgba(0,0,0,0.3);
            border-radius: 12px;
            overflow: hidden;
            height: 280px;
        }

        .graph-functions-list {
            display: flex;
            flex-direction: column;
            gap: 6px;
            margin-bottom: 12px;
        }

        .graph-fn-item {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,255,255,0.04);
            padding: 6px 10px;
            border-radius: 8px;
        }

        .fn-color-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .fn-label {
            flex: 1;
            font-size: 13px;
            color: var(--text-secondary);
            font-family: monospace;
        }

        .fn-remove {
            background: none;
            border: none;
            color: var(--btn-clear-color);
            cursor: pointer;
            font-size: 16px;
        }

        /* HISTORY PANEL */
        .history-list {
            max-height: 280px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .history-item {
            padding: 10px 12px;
            background: rgba(255,255,255,0.04);
            border-radius: 10px;
            cursor: pointer;
            transition: background 0.2s;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .history-item:hover { background: rgba(255,255,255,0.09); }

        .history-item .h-expr {
            font-size: 12px;
            color: var(--text-secondary);
        }

        .history-item .h-result {
            font-size: 18px;
            font-weight: 600;
            color: var(--text-primary);
        }

        .history-time {
            font-size: 10px;
            color: var(--text-secondary);
            opacity: 0.6;
        }

        /* THEME PANEL */
        .theme-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
        }

        .theme-card {
            border-radius: 12px;
            overflow: hidden;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            border: 2px solid transparent;
            position: relative;
        }

        .theme-card:hover { transform: translateY(-3px); }

        .theme-card.active {
            border-color: var(--accent);
            box-shadow: 0 0 20px rgba(79,172,254,0.4);
        }

        .theme-preview {
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .theme-name {
            text-align: center;
            font-size: 11px;
            padding: 6px;
            background: rgba(0,0,0,0.3);
            color: var(--text-primary);
        }

        .theme-check {
            position: absolute;
            top: 4px;
            right: 6px;
            font-size: 14px;
            display: none;
        }

        .theme-card.active .theme-check { display: block; }

        /* CONVERTER PANEL */
        .converter-tabs {
            display: flex;
            gap: 6px;
            margin-bottom: 14px;
            overflow-x: auto;
            padding-bottom: 4px;
        }

        .converter-tab {
            flex-shrink: 0;
            padding: 5px 12px;
            border: 1px solid var(--border-color);
            border-radius: 20px;
            background: transparent;
            color: var(--text-secondary);
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .converter-tab.active {
            background: rgba(100,180,255,0.15);
            border-color: var(--accent);
            color: var(--accent);
        }

        .converter-row {
            display: flex;
            gap: 10px;
            align-items: center;
            margin-bottom: 10px;
        }

        .converter-input {
            flex: 1;
            padding: 10px 14px;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            color: var(--text-primary);
            font-size: 14px;
            outline: none;
        }

        .converter-select {
            flex: 1;
            padding: 10px 14px;
            background: rgba(30,30,60,0.8);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            color: var(--text-primary);
            font-size: 13px;
            outline: none;
            cursor: pointer;
        }

        .converter-result {
            background: rgba(255,255,255,0.04);
            border-radius: 10px;
            padding: 12px 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .conv-result-val {
            font-size: 22px;
            font-weight: 600;
            color: var(--text-primary);
        }

        .conv-result-unit {
            font-size: 13px;
            color: var(--text-secondary);
        }

        /* INSTALL PROMPT */
        .install-prompt {
            display: none;
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(20,20,40,0.95);
            backdrop-filter: blur(20px);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 16px 20px;
            width: 90%;
            max-width: 380px;
            z-index: 1000;
            box-shadow: 0 10px 40px rgba(0,0,0,0.5);
            animation: slideUp 0.4s ease;
        }

        @keyframes slideUp {
            from { transform: translateX(-50%) translateY(100%); opacity: 0; }
            to { transform: translateX(-50%) translateY(0); opacity: 1; }
        }

        .install-prompt.visible { display: block; }

        .install-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 12px;
        }

        .install-icon {
            font-size: 32px;
        }

        .install-text h3 {
            font-size: 15px;
            color: var(--text-primary);
        }

        .install-text p {
            font-size: 12px;
            color: var(--text-secondary);
        }

        .install-actions {
            display: flex;
            gap: 10px;
        }

        .install-btn {
            flex: 1;
            padding: 10px;
            border: none;
            border-radius: 10px;
            cursor: pointer;
